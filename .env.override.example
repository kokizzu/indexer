PASSWORD=change-me
CLICKHOUSE_PASSWORD=change-me

SORTED_MOVIES="
/real/path/to/sorted/root-a
/real/path/to/sorted/root-b
"

UNSORTED_MOVIES="
/real/path/to/unsorted/root-a
/real/path/to/unsorted/root-b
"

BACKUP_SOURCES="
/home/me/.ssh
/home/me/.config
/etc
"

EXCLUDE_SOURCES="
/home/me/.config/chromium/Cache
*.cache
"

BACKUP_TARGET=/mnt/backup/indexer
